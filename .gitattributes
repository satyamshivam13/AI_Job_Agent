# Normalize line endings to LF in the repo, checkout as-is on all platforms
* text=auto eol=lf
*.py text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.sh text eol=lf

# Binaries — no line-ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.docx binary
*.db binary
