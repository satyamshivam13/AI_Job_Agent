# =============================================================================
# AI Job Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# =============================================================================
# LLM PROVIDERS (At least one required)
# =============================================================================

# Groq (FREE - Recommended for start) - https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenAI (Paid but best quality) - https://platform.openai.com
OPENAI_API_KEY=sk-your_openai_api_key_here

# Anthropic Claude (Optional) - https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# Together AI (Budget option) - https://api.together.xyz
TOGETHER_API_KEY=your_together_api_key_here

# =============================================================================
# EMBEDDINGS (Choose one)
# =============================================================================

# Voyage AI (FREE 1M tokens/month) - https://www.voyageai.com
VOYAGE_API_KEY=pa-your_voyage_api_key_here

# OR use OpenAI embeddings (if you have OpenAI key above)
USE_OPENAI_EMBEDDINGS=false

# =============================================================================
# DATABASE (Required)
# =============================================================================

# Supabase (FREE tier available) - https://supabase.com
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# =============================================================================
# VECTOR DATABASE (Choose one)
# =============================================================================

# ChromaDB (Local - Free)
VECTOR_DB_TYPE=chromadb
CHROMA_DB_PATH=./data/chroma

# OR Pinecone (Cloud - Free tier) - https://www.pinecone.io
# VECTOR_DB_TYPE=pinecone
# PINECONE_API_KEY=your_pinecone_api_key_here
# PINECONE_ENVIRONMENT=us-east-1

# =============================================================================
# JOB PLATFORM CREDENTIALS (Optional but recommended)
# =============================================================================

# LinkedIn
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# Indeed
INDEED_EMAIL=your_email@example.com
INDEED_PASSWORD=your_indeed_password

# Glassdoor
GLASSDOOR_EMAIL=your_email@example.com
GLASSDOOR_PASSWORD=your_glassdoor_password

# Wellfound (AngelList)
WELLFOUND_EMAIL=your_email@example.com
WELLFOUND_PASSWORD=your_wellfound_password

# Naukri (India)
NAUKRI_EMAIL=your_email@example.com
NAUKRI_PASSWORD=your_naukri_password

# =============================================================================
# BROWSER AUTOMATION (Optional)
# =============================================================================

# Use headless mode (recommended for production)
HEADLESS_BROWSER=true

# Proxy settings (optional - helps avoid rate limits)
USE_PROXY=false
PROXY_URL=http://username:password@proxy-server:port

# Residential proxies (recommended for production)
# PROXY_PROVIDER=brightdata  # or luminati, smartproxy, oxylabs
# PROXY_USERNAME=your_proxy_username
# PROXY_PASSWORD=your_proxy_password

# =============================================================================
# CAPTCHA SOLVING (Optional)
# =============================================================================

# 2Captcha (Pay per CAPTCHA solved) - https://2captcha.com
TWO_CAPTCHA_API_KEY=your_2captcha_api_key_here
ENABLE_CAPTCHA_SOLVER=false

# =============================================================================
# EMAIL NOTIFICATIONS (Optional)
# =============================================================================

# Gmail SMTP (for application notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password  # Use App Password, not regular password
NOTIFICATION_EMAIL=your_email@gmail.com

# =============================================================================
# SLACK NOTIFICATIONS (Optional)
# =============================================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# =============================================================================
# MONITORING & LOGGING (Optional)
# =============================================================================

# Sentry for error tracking - https://sentry.io
SENTRY_DSN=your_sentry_dsn_here
ENABLE_SENTRY=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Application mode
ENVIRONMENT=development  # development, production, testing

# Daily application limits (safety)
MAX_APPLICATIONS_PER_DAY=50
MAX_APPLICATIONS_PER_PLATFORM=20

# Automation delays (milliseconds - helps avoid detection)
MIN_DELAY_BETWEEN_ACTIONS=1000
MAX_DELAY_BETWEEN_ACTIONS=3000

# Retry settings
MAX_RETRIES=3
RETRY_DELAY=5

# =============================================================================
# USER PROFILE (Configure in config/user_profile.json instead)
# =============================================================================
# Or set basic info here:
USER_NAME=Satyam Shivam
USER_EMAIL=shivamsatyam35@gmail.com
USER_PHONE=+919852015381
USER_LOCATION=New Delhi, India

# =============================================================================
# API SERVER (FastAPI)
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your_jwt_secret_key_here_generate_with_openssl
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# REDIS (For caching and task queue)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# SCHEDULING
# =============================================================================

# When to run daily job search (24-hour format)
DAILY_RUN_TIME=09:00

# Time zone
TIMEZONE=Asia/Kolkata

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable features
ENABLE_AUTO_APPLY=true
ENABLE_RESUME_TAILORING=true
ENABLE_COVER_LETTER_GENERATION=true
ENABLE_DUPLICATE_DETECTION=true
ENABLE_ANALYTICS=true

# Risk settings
REQUIRE_HUMAN_APPROVAL=false  # Set true for risky applications
ENABLE_SCREENSHOT_CAPTURE=true
ENABLE_APPLICATION_PREVIEW=true

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================

# Debug mode
DEBUG=false

# Hot reload
RELOAD=true

# Test mode (doesn't actually submit applications)
TEST_MODE=false
